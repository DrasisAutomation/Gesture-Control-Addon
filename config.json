{
  "name": "Gesture Control for Smart Home",
  "version": "2.2.6",
  "slug": "gesture_control",
  "description": "Control up to 5 smart devices using hand gestures via RTSP camera",
  "arch": ["armhf", "armv7", "aarch64", "amd64", "i386"],
  "startup": "application",
  "boot": "auto",
  "host_network": true,
  "options": {
    "rtsp_url": "rtsp://your-camera-ip:554/stream",
    "ha_url": "ws://homeassistant.local:8123/api/websocket",
    "ha_token": "",
    "entity_1": "light.light_1",
    "entity_2": "light.light_2",
    "entity_3": "light.light_3",
    "entity_4": "light.light_4",
    "entity_5": "light.light_5",
    "fps": 15,
    "frame_width": 640,
    "frame_height": 480,
    "bitrate": "500k",
    "cooldown_seconds": 1,
    "detection_confidence": 0.5,
    "tracking_confidence": 0.5,
    "reset_gesture": 0,
    "stability_frames": 5
  },
  "schema": {
    "rtsp_url": "str",
    "ha_url": "str",
    "ha_token": "str",
    "entity_1": "str",
    "entity_2": "str",
    "entity_3": "str",
    "entity_4": "str",
    "entity_5": "str",
    "fps": "int(5,30)",
    "frame_width": "int(320,1920)",
    "frame_height": "int(240,1080)",
    "bitrate": "str",
    "cooldown_seconds": "int(0,5)",
    "detection_confidence": "float(0.3,0.9)",
    "tracking_confidence": "float(0.3,0.9)",
    "reset_gesture": "int(0,5)",
    "stability_frames": "int(3,10)"
  },
  "ports": {
    "8099/tcp": 8099
  },
  "webui": "http://[HOST]:[PORT:8099]",
  "map": ["config:rw"]
}